        { "name": "newScore", "type": "u64" }
      ]
    },
    {
      "name": "ProtocolPaused",
      "fields": [
        { "name": "authority", "type": "publicKey" }
      ]
    },
    {
      "name": "ProtocolResumed",
      "fields": [
        { "name": "authority", "type": "publicKey" }
      ]
    }
  ],
  "errors": [
    { "code": 100, "name": "InvalidReputation", "msg": "Invalid reputation score" },
    { "code": 101, "name": "NotPaused", "msg": "Protocol is not paused" },
