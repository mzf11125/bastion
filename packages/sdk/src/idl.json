      }
    },
    {
      "name": "agent",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "type": "publicKey" },
          { "name": "name", "type": "string" },
          { "name": "capabilityBitmask", "type": "u64" },
          { "name": "reputationScore", "type": "u64" },
          { "name": "registeredAt", "type": "i64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "policy",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "type": "publicKey" },
          { "name": "allowedPrograms", "type": { "array": [{ "array": ["u8", 32] }] } },
